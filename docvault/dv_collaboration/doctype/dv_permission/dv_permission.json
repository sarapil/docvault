{
  "name": "DV Permission",
  "module": "DV Collaboration",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "Expression",
  "autoname": "DV-PERM-.#####",
  "fields": [
    {
      "fieldname": "document",
      "fieldtype": "Link",
      "options": "DV Document",
      "label": "Document"
    },
    {
      "fieldname": "folder",
      "fieldtype": "Link",
      "options": "DV Folder",
      "label": "Folder"
    },
    {
      "fieldname": "permission_for",
      "fieldtype": "Select",
      "options": "User\nRole\nGroup",
      "label": "Permission For",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "user",
      "fieldtype": "Link",
      "options": "User",
      "label": "User",
      "depends_on": "eval:doc.permission_for=='User'"
    },
    {
      "fieldname": "role",
      "fieldtype": "Link",
      "options": "Role",
      "label": "Role",
      "depends_on": "eval:doc.permission_for=='Role'"
    },
    {
      "fieldname": "permission_level",
      "fieldtype": "Select",
      "options": "View\nDownload\nEdit\nAdmin",
      "label": "Permission Level",
      "reqd": 1,
      "in_list_view": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}