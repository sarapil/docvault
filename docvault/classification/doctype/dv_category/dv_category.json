{
  "name": "DV Category",
  "module": "Classification",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "By fieldname",
  "autoname": "field:category_name",
  "fields": [
    {
      "fieldname": "category_name",
      "fieldtype": "Data",
      "label": "Category Name",
      "reqd": 1
    },
    {
      "fieldname": "parent_category",
      "fieldtype": "Link",
      "options": "DV Category",
      "label": "Parent Category"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "icon",
      "fieldtype": "Data",
      "label": "Icon"
    },
    {
      "fieldname": "color",
      "fieldtype": "Color",
      "label": "Color"
    },
    {
      "fieldname": "default_retention_days",
      "fieldtype": "Int",
      "label": "Default Retention (Days)"
    },
    {
      "fieldname": "requires_approval",
      "fieldtype": "Check",
      "label": "Requires Approval"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}