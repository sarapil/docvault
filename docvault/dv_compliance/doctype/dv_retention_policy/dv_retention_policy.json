{
  "name": "DV Retention Policy",
  "module": "DV Compliance",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "By fieldname",
  "autoname": "field:policy_name",
  "fields": [
    {
      "fieldname": "policy_name",
      "fieldtype": "Data",
      "label": "Policy Name",
      "reqd": 1
    },
    {
      "fieldname": "category",
      "fieldtype": "Link",
      "options": "DV Category",
      "label": "Category",
      "in_list_view": 1
    },
    {
      "fieldname": "retention_years",
      "fieldtype": "Int",
      "label": "Retention Years",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "action_after",
      "fieldtype": "Select",
      "options": "Archive\nFlag\nDelete",
      "label": "Action After Retention",
      "default": "Archive",
      "in_list_view": 1
    },
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Enabled",
      "default": "1"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "legal_reference",
      "fieldtype": "Data",
      "label": "Legal Reference"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}