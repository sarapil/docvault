{
  "name": "DV Controlled Document",
  "module": "DV Compliance",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "Expression",
  "autoname": "DV-CTRL-.#####",
  "fields": [
    {
      "fieldname": "document",
      "fieldtype": "Link",
      "options": "DV Document",
      "label": "Document",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "control_number",
      "fieldtype": "Data",
      "label": "Control Number",
      "unique": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "revision",
      "fieldtype": "Data",
      "label": "Revision"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "options": "Draft\nPending Approval\nEffective\nObsolete\nWithdrawn",
      "label": "Status",
      "default": "Draft",
      "in_list_view": 1
    },
    {
      "fieldname": "effective_date",
      "fieldtype": "Date",
      "label": "Effective Date"
    },
    {
      "fieldname": "next_review",
      "fieldtype": "Date",
      "label": "Next Review Date"
    },
    {
      "fieldname": "owner_role",
      "fieldtype": "Link",
      "options": "Role",
      "label": "Owner Role"
    },
    {
      "fieldname": "distribution_list",
      "fieldtype": "Small Text",
      "label": "Distribution List"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}