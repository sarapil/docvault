{
  "name": "DV Watermark",
  "module": "DV Compliance",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "By fieldname",
  "autoname": "field:watermark_name",
  "fields": [
    {
      "fieldname": "watermark_name",
      "fieldtype": "Data",
      "label": "Watermark Name",
      "reqd": 1
    },
    {
      "fieldname": "watermark_type",
      "fieldtype": "Select",
      "options": "Text\nImage",
      "label": "Type",
      "reqd": 1
    },
    {
      "fieldname": "text",
      "fieldtype": "Data",
      "label": "Watermark Text",
      "depends_on": "eval:doc.watermark_type=='Text'"
    },
    {
      "fieldname": "image",
      "fieldtype": "Attach Image",
      "label": "Watermark Image",
      "depends_on": "eval:doc.watermark_type=='Image'"
    },
    {
      "fieldname": "opacity",
      "fieldtype": "Percent",
      "label": "Opacity",
      "default": "30"
    },
    {
      "fieldname": "position",
      "fieldtype": "Select",
      "options": "Center\nTop Left\nTop Right\nBottom Left\nBottom Right\nDiagonal",
      "label": "Position",
      "default": "Diagonal"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}