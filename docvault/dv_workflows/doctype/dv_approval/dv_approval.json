{
  "name": "DV Approval",
  "module": "DV Workflows",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "Expression",
  "autoname": "DV-APR-.#####",
  "fields": [
    {
      "fieldname": "document",
      "fieldtype": "Link",
      "options": "DV Document",
      "label": "Document",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "approver",
      "fieldtype": "Link",
      "options": "User",
      "label": "Approver",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "options": "Pending\nApproved\nRejected\nCancelled",
      "label": "Status",
      "default": "Pending",
      "in_list_view": 1
    },
    {
      "fieldname": "level",
      "fieldtype": "Int",
      "label": "Approval Level",
      "default": "1"
    },
    {
      "fieldname": "comments",
      "fieldtype": "Small Text",
      "label": "Comments"
    },
    {
      "fieldname": "approved_at",
      "fieldtype": "Datetime",
      "label": "Approved At",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}