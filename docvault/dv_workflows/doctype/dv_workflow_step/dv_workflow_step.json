{
  "name": "DV Workflow Step",
  "module": "DV Workflows",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 1,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "autoincrement",
  "autoname": "",
  "fields": [
    {
      "fieldname": "step_name",
      "fieldtype": "Data",
      "label": "Step Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "step_type",
      "fieldtype": "Select",
      "options": "Review\nApproval\nNotification",
      "label": "Type",
      "in_list_view": 1
    },
    {
      "fieldname": "assigned_role",
      "fieldtype": "Link",
      "options": "Role",
      "label": "Assigned Role",
      "in_list_view": 1
    },
    {
      "fieldname": "order_index",
      "fieldtype": "Int",
      "label": "Order",
      "in_list_view": 1
    },
    {
      "fieldname": "required",
      "fieldtype": "Check",
      "label": "Required",
      "default": "1"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}