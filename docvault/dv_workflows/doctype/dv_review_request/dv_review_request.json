{
  "name": "DV Review Request",
  "module": "DV Workflows",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "Expression",
  "autoname": "DV-REV-.#####",
  "fields": [
    {
      "fieldname": "document",
      "fieldtype": "Link",
      "options": "DV Document",
      "label": "Document",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "reviewer",
      "fieldtype": "Link",
      "options": "User",
      "label": "Reviewer",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "options": "Pending\nIn Review\nApproved\nRejected\nReturned",
      "label": "Status",
      "default": "Pending",
      "in_list_view": 1
    },
    {
      "fieldname": "review_type",
      "fieldtype": "Select",
      "options": "Content Review\nCompliance Review\nTechnical Review\nFinal Approval",
      "label": "Review Type"
    },
    {
      "fieldname": "due_date",
      "fieldtype": "Date",
      "label": "Due Date"
    },
    {
      "fieldname": "comments",
      "fieldtype": "Small Text",
      "label": "Comments"
    },
    {
      "fieldname": "reviewed_at",
      "fieldtype": "Datetime",
      "label": "Reviewed At",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}