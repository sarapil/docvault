{
  "name": "DV OCR Result",
  "module": "DV Search",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "Expression",
  "autoname": "DV-OCR-.#####",
  "fields": [
    {
      "fieldname": "document",
      "fieldtype": "Link",
      "options": "DV Document",
      "label": "Document",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "options": "Pending\nProcessing\nCompleted\nFailed",
      "label": "Status",
      "default": "Pending",
      "in_list_view": 1
    },
    {
      "fieldname": "ocr_provider",
      "fieldtype": "Data",
      "label": "OCR Provider"
    },
    {
      "fieldname": "extracted_text",
      "fieldtype": "Long Text",
      "label": "Extracted Text"
    },
    {
      "fieldname": "confidence",
      "fieldtype": "Percent",
      "label": "Confidence"
    },
    {
      "fieldname": "processed_at",
      "fieldtype": "Datetime",
      "label": "Processed At",
      "read_only": 1
    },
    {
      "fieldname": "language",
      "fieldtype": "Data",
      "label": "Detected Language"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}