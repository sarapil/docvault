{
  "name": "DV Version",
  "module": "DV Core",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "Expression",
  "autoname": "DV-VER-.#####",
  "fields": [
    {
      "fieldname": "document",
      "fieldtype": "Link",
      "options": "DV Document",
      "label": "Document",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "version_no",
      "fieldtype": "Int",
      "label": "Version No",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "file",
      "fieldtype": "Attach",
      "label": "File"
    },
    {
      "fieldname": "change_notes",
      "fieldtype": "Small Text",
      "label": "Change Notes"
    },
    {
      "fieldname": "created_by",
      "fieldtype": "Link",
      "options": "User",
      "label": "Created By",
      "read_only": 1
    },
    {
      "fieldname": "file_hash",
      "fieldtype": "Data",
      "label": "File Hash (SHA-256)",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}