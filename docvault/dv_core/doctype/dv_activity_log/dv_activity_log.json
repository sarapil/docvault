{
  "name": "DV Activity Log",
  "module": "DV Core",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "Expression",
  "autoname": "DV-ACT-.#####",
  "fields": [
    {
      "fieldname": "document",
      "fieldtype": "Link",
      "options": "DV Document",
      "label": "Document",
      "in_list_view": 1
    },
    {
      "fieldname": "activity_type",
      "fieldtype": "Select",
      "options": "Created\nUpdated\nVersioned\nShared\nCommented\nApproved\nRejected\nArchived\nDeleted",
      "label": "Activity",
      "in_list_view": 1
    },
    {
      "fieldname": "user",
      "fieldtype": "Link",
      "options": "User",
      "label": "User"
    },
    {
      "fieldname": "details",
      "fieldtype": "Small Text",
      "label": "Details"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}