{
  "name": "DV Template",
  "module": "DV Core",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "By fieldname",
  "autoname": "field:template_name",
  "fields": [
    {
      "fieldname": "template_name",
      "fieldtype": "Data",
      "label": "Template Name",
      "reqd": 1
    },
    {
      "fieldname": "category",
      "fieldtype": "Link",
      "options": "DV Category",
      "label": "Category"
    },
    {
      "fieldname": "file",
      "fieldtype": "Attach",
      "label": "Template File"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "file_type",
      "fieldtype": "Select",
      "options": "PDF\nWord\nExcel\nPowerPoint\nOther",
      "label": "File Type"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}