{
  "name": "DV Document",
  "module": "DV Core",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "Expression",
  "autoname": "DV-DOC-.#####",
  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "file",
      "fieldtype": "Attach",
      "label": "File",
      "reqd": 1
    },
    {
      "fieldname": "category",
      "fieldtype": "Link",
      "options": "DV Category",
      "label": "Category",
      "in_list_view": 1
    },
    {
      "fieldname": "folder",
      "fieldtype": "Link",
      "options": "DV Folder",
      "label": "Folder"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "options": "Draft\nActive\nUnder Review\nApproved\nObsolete\nArchived",
      "label": "Status",
      "default": "Draft",
      "in_list_view": 1
    },
    {
      "fieldname": "cb1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "version_number",
      "fieldtype": "Int",
      "label": "Version",
      "read_only": 1,
      "default": "1",
      "in_list_view": 1
    },
    {
      "fieldname": "file_size",
      "fieldtype": "Int",
      "label": "File Size (bytes)",
      "read_only": 1
    },
    {
      "fieldname": "file_type",
      "fieldtype": "Data",
      "label": "File Type",
      "read_only": 1
    },
    {
      "fieldname": "source_file",
      "fieldtype": "Link",
      "options": "File",
      "label": "Source File",
      "read_only": 1
    },
    {
      "fieldname": "sb_meta",
      "fieldtype": "Section Break",
      "label": "Metadata"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "tags",
      "fieldtype": "Table",
      "options": "DV Document Tag",
      "label": "Tags"
    },
    {
      "fieldname": "keywords",
      "fieldtype": "Small Text",
      "label": "Keywords"
    },
    {
      "fieldname": "sb_checkout",
      "fieldtype": "Section Break",
      "label": "Checkout"
    },
    {
      "fieldname": "checked_out_by",
      "fieldtype": "Link",
      "options": "User",
      "label": "Checked Out By",
      "read_only": 1
    },
    {
      "fieldname": "checked_out_at",
      "fieldtype": "Datetime",
      "label": "Checked Out At",
      "read_only": 1
    },
    {
      "fieldname": "sb_compliance",
      "fieldtype": "Section Break",
      "label": "Compliance"
    },
    {
      "fieldname": "document_number",
      "fieldtype": "Data",
      "label": "Document Number"
    },
    {
      "fieldname": "effective_date",
      "fieldtype": "Date",
      "label": "Effective Date"
    },
    {
      "fieldname": "expiry_date",
      "fieldtype": "Date",
      "label": "Expiry Date"
    },
    {
      "fieldname": "confidentiality",
      "fieldtype": "Select",
      "options": "Public\nInternal\nConfidential\nRestricted",
      "label": "Confidentiality",
      "default": "Internal"
    },
    {
      "fieldname": "sb_search",
      "fieldtype": "Section Break",
      "label": "Search"
    },
    {
      "fieldname": "indexed",
      "fieldtype": "Check",
      "label": "Indexed",
      "hidden": 1,
      "default": "0"
    },
    {
      "fieldname": "ocr_text",
      "fieldtype": "Long Text",
      "label": "OCR Text",
      "hidden": 1
    },
    {
      "fieldname": "retention_flagged",
      "fieldtype": "Check",
      "label": "Retention Flagged",
      "hidden": 1
    },
    {
      "fieldname": "sb_reference",
      "fieldtype": "Section Break",
      "label": "Reference"
    },
    {
      "fieldname": "reference_doctype",
      "fieldtype": "Link",
      "options": "DocType",
      "label": "Reference DocType"
    },
    {
      "fieldname": "reference_name",
      "fieldtype": "Dynamic Link",
      "options": "reference_doctype",
      "label": "Reference Name"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}