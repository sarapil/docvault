{
  "name": "DV Folder",
  "module": "DV Core",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "By fieldname",
  "autoname": "field:folder_name",
  "fields": [
    {
      "fieldname": "folder_name",
      "fieldtype": "Data",
      "label": "Folder Name",
      "reqd": 1
    },
    {
      "fieldname": "parent_folder",
      "fieldtype": "Link",
      "options": "DV Folder",
      "label": "Parent Folder"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "icon",
      "fieldtype": "Data",
      "label": "Icon"
    },
    {
      "fieldname": "is_root",
      "fieldtype": "Check",
      "label": "Is Root Folder",
      "default": "0"
    },
    {
      "fieldname": "allowed_roles",
      "fieldtype": "Small Text",
      "label": "Allowed Roles (JSON)"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DV Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}